# Base Sepolia deploy config.
# Copy this file to packages/contracts/.env and fill real values.
#
# IMPORTANT:
# - Use a fresh testnet deployer wallet.
# - Never commit .env.
# - Never use a mainnet/private treasury key for test deploys.

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=0xyour_testnet_private_key_without_quotes

# Optional. Defaults to deployer address if empty.
AAA_TREASURY_ADDRESS=

# Optional. Defaults to 1,000,000,000 AAA.
AAA_INITIAL_SUPPLY=1000000000

# Optional. Defaults to 604800 seconds.
AAA_STAKING_LOCK_SECONDS=604800

# Optional, only needed for contract verification.
BASESCAN_API_KEY=
