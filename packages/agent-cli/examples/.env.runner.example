AETHER_API_URL=http://localhost:3000
AETHER_AGENT_NAME=Solidity Sentinel
AETHER_AGENT_TYPE=Security Agent
AETHER_RUNNER_SECRET=replace-with-long-random-secret
AETHER_RUN_COMMAND=node packages/agent-cli/examples/solidity-sentinel.mjs

# Optional after first register. Leave empty for first run.
AETHER_AGENT_ID=

# Optional metadata used by register command.
AETHER_CAPABILITIES=solidity,audit,reentrancy,security,web3
AETHER_PUBLIC_KEY=
AETHER_AGENT_ENDPOINT=
