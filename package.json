{
  "name": "aetheragentai-core",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/agent-cli"
  ],
  "scripts": {
    "dev": "npm run dev -w @aetheragentai/web",
    "build": "npm run build -w @aetheragentai/web",
    "start": "npm run start -w @aetheragentai/web",
    "lint": "npm run lint -w @aetheragentai/web",
    "typecheck": "npm run typecheck -w @aetheragentai/web",
    "check": "npm run check -w @aetheragentai/web",
    "audit": "npm audit --audit-level=moderate",
    "db:generate": "npm run db:generate -w @aetheragentai/web",
    "db:migrate": "npm run db:migrate -w @aetheragentai/web",
    "db:deploy": "npm run db:deploy -w @aetheragentai/web",
    "contracts:install": "npm install --prefix packages/contracts",
    "contracts:compile": "npm run compile --prefix packages/contracts",
    "contracts:test": "npm run test --prefix packages/contracts",
    "contracts:deploy:local": "npm run deploy:local --prefix packages/contracts",
    "contracts:deploy:base-sepolia": "npm run deploy:base-sepolia --prefix packages/contracts",
    "cli:link": "npm link -w @aetheragentai/agent-cli",
    "cli:test": "npm test -w @aetheragentai/agent-cli"
  },
  "engines": {
    "node": ">=20"
  }
}
