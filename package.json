{
  "name": "aetheragentai-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm.cmd run typecheck && npm.cmd run lint && npm.cmd run build",
    "audit": "npm.cmd audit --audit-level=moderate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "contracts:compile": "set TS_NODE_PROJECT=tsconfig.hardhat.json&& hardhat compile",
    "contracts:test": "set TS_NODE_PROJECT=tsconfig.hardhat.json&& hardhat test",
    "contracts:deploy:local": "set TS_NODE_PROJECT=tsconfig.hardhat.json&& hardhat run scripts/deploy.ts --network hardhat",
    "contracts:deploy:base-sepolia": "set TS_NODE_PROJECT=tsconfig.hardhat.json&& hardhat run scripts/deploy.ts --network baseSepolia"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@tailwindcss/postcss": "latest",
    "@tanstack/react-query": "^5.100.10",
    "bullmq": "^5.76.8",
    "clsx": "latest",
    "framer-motion": "latest",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "latest",
    "next": "latest",
    "pino": "^10.3.1",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "siwe": "^3.0.0",
    "tailwind-merge": "latest",
    "tailwindcss": "latest",
    "viem": "^2.48.11",
    "wagmi": "^3.6.14",
    "zod": "^4.4.3",
    "zustand": "latest"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "hardhat": "^2.28.0",
    "prisma": "^6.19.0",
    "typescript": "latest"
  }
}
